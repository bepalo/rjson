{
  "name": "@bepalo/rjson",
  "version": "1.0.1",
  "exports": {
    ".": "./mod.ts",
    "./mod.ts": "./mod.ts"
  },
  "description": "A compact, URL-friendly serialization format that is smaller than JSON while remaining human-readable and fast to parse.",
  "license": "MIT",
  "homepage": "https://github.com/bepalo/rjson",
  "repository": {
    "type": "git",
    "url": "https://github.com/bepalo/rjson"
  },
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "include": ["./src/", "./tests/"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports"]
    }
  },
  "fmt": {
    "include": ["./src/", "./tests/"],
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "test": {
    "files": {
      "exclude": ["tests/**", "**/*.vitest.ts"]
    }
  },
  "imports": {},
  "keywords": ["parser", "RJSON", "JSON", "fetch", "REST", "URL", "query"]
}
